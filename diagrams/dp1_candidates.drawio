          <mxGeometry x="1050" y="584" width="270" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c2tl" value="&lt;b&gt;Tier &amp;amp; Lifecycle&lt;/b&gt;&lt;br&gt;Tier Topology Model (자사 HW 로드맵 직접 수용) · Migration · KV Transport&lt;br&gt;&lt;font color=&quot;#1B7A4B&quot;&gt;자사 디바이스(HBM4·CMM-DC·HBF) 확장점 제약 없음 — QA4(자사 HW) 최고&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#44546A;fontColor=#1F2A44;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="754" y="680" width="566" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c2risk" value="&lt;b&gt;리스크:&lt;/b&gt; 배칭·모델 지원·수치 검증을 전부 자체 구축 + 영구 추종 (수십 인월+, vLLM 동등 baseline 도달 자체가 선행 과제 — QA1 상한과 도달 확률의 분리)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#B3402A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="816" width="610" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="legend" value="범례:  녹색 = 구조적 이득 지점 · 주황 점선 = MCR 신설/주입 · 베이지 = 3rd-party (vLLM·LMCache) · 굵은 점선 테두리 = 변형 선택 슬롯 · 적색 텍스트 = 구조적 제약/리스크" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#1F2A44;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="44" y="920" width="1200" height="26" as="geometry"/>
