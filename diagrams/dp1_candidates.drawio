        <mxCell id="c2tas" value="&lt;b&gt;Tier-aware Scheduler&lt;/b&gt;&lt;br&gt;tier 잔량·KV 위치·압축 상태가&lt;br&gt;admission·배칭 결정에 직접 반영" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E9F5EE;strokeColor=#1B7A4B;fontColor=#155F3B;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
