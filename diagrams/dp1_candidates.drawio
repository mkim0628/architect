        <mxCell id="c2sec" value="&lt;b&gt;Step Execution Controller&lt;/b&gt;&lt;br&gt;continuous batching·chunked prefill&lt;br&gt;&lt;font color=&quot;#B3402A&quot;&gt;전부 자체 재구현 대상&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#44546A;fontColor=#1F2A44;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
