        <mxCell id="c2kl" value="&lt;b&gt;Kernel &amp;amp; Layer&lt;/b&gt;&lt;br&gt;FlashInfer/자체 Attention · MoE Dispatcher · Custom Kernel · CompressionOp(DI 구현)&lt;br&gt;&lt;font color=&quot;#6B7A90&quot;&gt;모델 zoo·신규 기법 포팅을 자체 유지 (upstream 부재)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#44546A;fontColor=#1F2A44;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="754" y="362" width="566" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c2me" value="«MCR» Memory Engine — 설계 중심 (1급 패키지)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#44546A;fontColor=#1F2A44;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="730" y="546" width="610" height="256" as="geometry"/>
        </mxCell>
        <mxCell id="c2edgeCo" value="placement × scheduling co-design — 본 후보의 핵심 이득 (QA1·QA2 상한)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=block;strokeColor=#1B7A4B;strokeWidth=2.5;fontSize=10;fontColor=#1B7A4B;fontStyle=1;exitX=0.22;exitY=1;exitDx=0;exitDy=0;entryX=0.22;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="c2ie" target="c2me">
