        <mxCell id="c1bc" value="&lt;b&gt;질의 임베딩 브로드캐스트&lt;/b&gt;&lt;br&gt;전 파티션 동시 발행" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#44546A;fontColor=#1F2A44;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
