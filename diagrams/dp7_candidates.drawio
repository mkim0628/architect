        <mxCell id="c1ssd" value="«SSD-PIM» 파티션들 — 코퍼스 샤딩 (인덱스 없음)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#44546A;fontColor=#1F2A44;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
