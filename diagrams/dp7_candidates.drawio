        <mxCell id="c2cl2" value="클러스터 7&lt;br&gt;스킵" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C9D2DE;fontColor=#9AA6B5;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
