        </mxCell>
        <mxCell id="c2nand" value="불규칙(클러스터 점프) NAND 접근 — PIM 스트리밍 모델과 상성 저하" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#B3402A;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="754" y="426" width="576" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="c2edge" value="선택된 클러스터 id만 전달" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#1F2A44;fontSize=10;fontColor=#1F2A44;" edge="1" parent="1" source="c2host" target="c2ssd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c2pipe" value="&lt;b&gt;증분 인덱싱 파이프라인 (신설) — 문서 추가 시 인덱스 빌드·갱신 경유&lt;/b&gt;&lt;br&gt;증분 갱신이 독립 연구 주제일 만큼 비용 실재 (SPFresh 계열, B)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDF6E9;strokeColor=#B45309;dashed=1;fontColor=#8A5A08;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="730" y="470" width="610" height="58" as="geometry"/>
        </mxCell>
        <mxCell id="c2gain" value="&lt;b&gt;이득:&lt;/b&gt; sublinear 지연 — billion-scale에서도 TTFT 예산 내 (SmartANNS QPS 최대 10.7×, B), 질의당 스캔 바이트·에너지 절감 · 코퍼스 상한이 인덱스 품질의 함수 (증설 없이 확장)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#1B7A4B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="542" width="610" height="46" as="geometry"/>
        </mxCell>
        <mxCell id="c2risk" value="&lt;b&gt;리스크:&lt;/b&gt; recall &lt; 100% — ANN 근사 손실이 응답 품질로 전이 (nprobe/ef 튜닝 상시 부담), 인덱스 빌드·증분 갱신 파이프라인 비용 (초기 6–24인월·유지 ≤2 FTE)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#B3402A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="594" width="610" height="46" as="geometry"/>
        </mxCell>
        <mxCell id="evo" value="&lt;b&gt;진화 경로 (검토 노트):&lt;/b&gt; 후보1로 시작(exact 품질 베이스라인 + 갱신 파이프라인 없이 E2E 완주) → 코퍼스가 임계(≈내부 유효 BW × TTFT 예산) 초과 시 상위 IVF 층만 추가해 계층형(상위 인덱스 + 클러스터 내 전수 스캔 = 두 후보의 수렴점)으로 전환 — 트리거를 ADR에 명시" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#6B7A90;dashed=1;fontColor=#1F2A44;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="1280" height="60" as="geometry"/>
        </mxCell>
