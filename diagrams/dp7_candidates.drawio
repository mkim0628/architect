        <mxCell id="c2cl3" value="&lt;b&gt;클러스터 12&lt;/b&gt;&lt;br&gt;부분 스캔 ✓" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EBF0;strokeColor=#44546A;fontColor=#1F2A44;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
