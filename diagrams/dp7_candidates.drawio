        <mxCell id="c1gain" value="&lt;b&gt;이득:&lt;/b&gt; recall 100% (exact) — 검색발 품질 저하 구조적 0 · 인덱스 유지비 0 (agent memory 상시 추가에 최강) · 지연 결정론적 (코퍼스/대역폭) — SLO 예측 가능 · 초기 ≤6인월" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#1B7A4B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="496" width="580" height="46" as="geometry"/>
        </mxCell>
        <mxCell id="c1risk" value="&lt;b&gt;제약:&lt;/b&gt; 지연 ≈ 코퍼스 바이트 / 내부 유효 BW — 코퍼스에 선형, TTFT 예산(450ms) 내 코퍼스 상한이 구조에 박힘 · 매 질의 전량 접근 (에너지·대역폭) · 상한 도달 시 대응 = 파티션 증설뿐 (비용 선형)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#B3402A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="548" width="580" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="h2" value="후보구조 2 — 인덱스 유도형 (IVF/graph-guided partial scan, SmartANNS형)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCE3EE;strokeColor=#44546A;fontColor=#1F2A44;fontSize=13;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="76" width="650" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="c2host" value="«Host» Retrieval Engine + 상위 인덱스" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#44546A;fontColor=#1F2A44;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="730" y="124" width="610" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="c2idx" value="&lt;b&gt;상위 인덱스 (host DRAM 상주)&lt;/b&gt;&lt;br&gt;IVF centroid / 그래프 상위층&lt;br&gt;→ 후보 클러스터 선별 (sublinear)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDF6E9;strokeColor=#B45309;dashed=1;fontColor=#8A5A08;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="160" width="280" height="70" as="geometry"/>
