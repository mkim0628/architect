<mxfile host="app.diagrams.net">
  <diagram id="mcr-package-v2" name="MCR Package Diagram v2">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1180" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;b&gt;MCR Overall Architecture — Package Diagram (확정안 v2)&lt;/b&gt;&lt;br&gt;실선: 의존(«use») · 회색 점선: telemetry · 주황 점선 화살표: 인터페이스 구현(DI) · 주황 점선 박스: 신규 컴포넌트 · v2: Retrieval→Orchestration 이동, Autoscaler 2중 루프화" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#1F2A44;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="14" width="1320" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="orchTab" value="«package»  Inference Orchestration" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCE3EE;strokeColor=#44546A;fontColor=#1F2A44;fontSize=12;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="84" width="310" height="26" as="geometry"/>
