          <mxGeometry x="70" y="140" width="400" height="314" as="geometry"/>
        </mxCell>
        <mxCell id="rlm" value="&lt;b&gt;Request Lifecycle Manager&lt;/b&gt;&lt;br&gt;(구: Request Manager) · admission" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#44546A;fontColor=#1F2A44;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
